[gd_resource type="Resource" script_class="BoardConfig" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/board_config.gd" id="1"]

[resource]
script = ExtResource("1")
layout_name = "4-Player Layout 1"
player_count = 4

# 3x3 grid of tile IDs, row-major. Index = row*3 + col.
# TODO: fill tile IDs from the official rulebook 4-player diagram 1.
tile_grid = Array[int]([ 0, 0, 0, 0, 0, 0, 0, 0, 0 ])

# Planet world positions (9x9 grid). Corner tiles for 4-player.
# Tile (col,row) -> planet at (col*3+1, row*3+1).
# Corners: (1,1), (7,1), (1,7), (7,7) for tiles (0,0), (2,0), (0,2), (2,2).
# TODO: verify against rulebook starting positions.
player_start_planets = Array[Vector2i]([ Vector2i(1, 1), Vector2i(7, 1), Vector2i(1, 7), Vector2i(7, 7) ])

# Starting ship positions: 3 ships per player, flat array (player i = indices i*3..i*3+2).
# Ships occupy 3 of the 4 orthogonal orbital spaces around the starting planet.
# TODO: verify exact starting ship positions from rulebook.
player_start_ships = Array[Vector2i]([ Vector2i(0, 1), Vector2i(2, 1), Vector2i(1, 0), Vector2i(6, 1), Vector2i(8, 1), Vector2i(7, 0), Vector2i(0, 7), Vector2i(2, 7), Vector2i(1, 8), Vector2i(6, 7), Vector2i(8, 7), Vector2i(7, 8) ])
